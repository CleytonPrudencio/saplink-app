# Obrigatórias
SAPLINK_URL=https://api.saplink.app
AGENT_TOKEN=cole-aqui-o-token-gerado-na-integracao

# Modo de coleta: mock (teste, sem SAP) | rfc (real, requer SAP NW RFC SDK)
SAP_MODE=mock
POLL_SECONDS=60

# Apenas no modo rfc (conexão RFC real)
SAP_ASHOST=10.0.0.10
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=SAPLINK_MON
SAP_PASSWD=trocar
SAP_LANG=PT

# Demonstração no modo mock: força um estado (healthy | error | offline)
# MOCK_FORCE=error
