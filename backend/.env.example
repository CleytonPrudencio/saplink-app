# Local development
DATABASE_URL="postgresql://saplink:saplink123@localhost:5433/saplink"

# Render production (set in Render dashboard)
# DATABASE_URL="postgresql://user:pass@host:5432/db"

# OBRIGATÓRIO: gere um valor forte e aleatório. O app NÃO sobe sem isso.
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
# OBRIGATÓRIO: chave para criptografar credenciais SAP em repouso (AES-256). Não perca em produção.
ENCRYPTION_KEY=""
# Origens permitidas no CORS (separadas por vírgula)
CORS_ORIGINS="http://localhost:3000"
ANTHROPIC_API_KEY=""
PORT=8080

# Simulação de métricas: SÓ para demo. Em produção deixe desligado (dados vêm do
# conector OData/REST real e do Agente on-premise).
SIMULATION_ENABLED=false
SIMULATION_INTERVAL=30000

# Popular o banco com dados DEMO (consultoria/clientes/integrações fictícios) no seed.
# Em produção deixe desligado — o banco começa vazio.
SEED_DEMO=false

# Agente on-premise: tempo sem reporte até marcar OFFLINE (ms)
AGENT_STALE_MS=180000
