generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Consultancy {
  id            String         @id @default(uuid())
  name          String         // nome de exibição (= nome fantasia)
  cnpj          String?        @unique
  razaoSocial   String?        // razão social (para a nota)
  nomeFantasia  String?
  ie            String?        // inscrição estadual
  phone         String?
  billingEmail  String?        // e-mail financeiro/nota
  // Endereço (nota fiscal)
  cep           String?
  logradouro    String?
  numero        String?
  complemento   String?
  bairro        String?
  cidade        String?
  uf            String?
  acceptedTermsAt DateTime?    // aceite dos termos no cadastro
  weeklyDigest  Boolean        @default(true)  // recebe o digest semanal por e-mail
  lastDigestAt  DateTime?      // último envio do digest semanal
  escalateAfterMin Int         @default(30)    // C1: minutos até escalar alerta não resolvido
  channels      NotificationChannel[]
  ticketConfig  TicketConfig?
  plan          String         @default("STARTER") // legado; fonte da verdade = Subscription
  logoUrl       String?
  primaryColor  String?        // white-label (hex)
  createdAt     DateTime       @default(now())
  users         User[]
  clients       Client[]
  subscription  Subscription?
  invoices      Invoice[]
  usageCounters UsageCounter[]
}

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  password      String
  name          String
  role          String               @default("CONSULTANCY_USER") // PLATFORM_ADMIN | CONSULTANCY_ADMIN | CONSULTANCY_ANALYST | CONSULTANCY_VIEWER (CONSULTANCY_USER = legado/analista)
  consultancyId String?              // PLATFORM_ADMIN não pertence a nenhuma consultoria
  consultancy   Consultancy?         @relation(fields: [consultancyId], references: [id])
  allClients    Boolean              @default(true) // true = vê todos os clientes da consultoria; false = só os de clientAccess
  clientAccess  UserClient[]
  createdAt     DateTime             @default(now())
  resetTokens   PasswordResetToken[]
}

// Acesso por cliente: quais clientes um usuário (analista/consulta restrito) pode ver.
model UserClient {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, clientId])
  @@index([clientId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Client {
  id            String        @id @default(uuid())
  name          String
  cnpj          String?
  consultancyId String
  consultancy   Consultancy   @relation(fields: [consultancyId], references: [id])
  healthScore   Int           @default(0)
  portalEnabled Boolean       @default(false) // C3: portal read-only do cliente final
  portalToken   String?       @unique          // token do link público do portal
  statusEnabled Boolean       @default(false)  // status page white-label (público)
  statusToken   String?       @unique          // token do link público do status page
  slaUptimeTarget Float       @default(99.0)   // D1: meta de uptime (%)
  slaMaxLatencyMs Int         @default(2000)   // D1: meta de latência (ms)
  transports    Transport[]
  reformItems     ReformReadiness[]
  licenseItems    LicenseItem[]
  userAccess      UserClient[]
  s4Connections   S4Connection[]
  upgradeFindings UpgradeFinding[]
  cleanCoreItems  CleanCoreItem[]
  apiUsages       ApiUsage[]
  commArrangements CommArrangement[]
  fiscalDocs      FiscalDoc[]
  cloudEvents     CloudEvent[]
  cpiConfigs      CpiConfig[]
  cloudConnectors CloudConnector[]
  btpResources    BtpResource[]
  opsSignals      OpsSignal[]
  integrations  Integration[]
  alerts        Alert[]
  diagnostics   Diagnostic[]
  deadCode      DeadCode[]
  sapItems      SapItem[]
  remediations  RemediationAction[]
  catalogItems  InterfaceCatalogItem[]
  createdAt     DateTime      @default(now())
}

model Integration {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String
  environment String   @default("PRD") // DEV | HML | PRD — separa dev/homologação/produção
  status      String   @default("ACTIVE")
  config      Json?
  latency     Int      @default(0)
  errorRate   Float    @default(0)
  uptime      Float    @default(100)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  alerts      Alert[]
  sapItems    SapItem[]
  // Agente on-premise (RFC/IDoc): token de ingestão e frescor da última leitura
  agentTokenHash    String?   @unique
  agentTokenHint    String?
  lastAgentReportAt DateTime?
  // A4 — Radar de validade: expiração de certificado TLS (auto-detectada) e de segredo (manual)
  certExpiresAt   DateTime?  // notAfter do certificado TLS do endpoint HTTPS
  certCheckedAt   DateTime?  // quando o cert foi verificado pela última vez
  certHost        String?    // host cujo cert foi lido
  secretExpiresAt DateTime?  // expiração manual: senha RFC, client secret OAuth, cert SNC...
  secretLabel     String?    // descrição do segredo (ex.: "Senha do usuário RFC")
  costPerHourCents Int       @default(0)  // D2: custo de parada por hora (centavos R$)
  businessProcess  String?   // D2: processo de negócio impactado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Alert {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String       @id @default(uuid())
  type          String
  severity      String
  message       String
  resolved      Boolean      @default(false)
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id])
  createdAt     DateTime     @default(now())
  resolvedAt    DateTime?
  // C1/C2 — notificação multicanal + ticket sync
  notifiedAt     DateTime?
  escalationLevel Int         @default(0)
  ticketKey      String?
  ticketUrl      String?
  ticketClosedAt DateTime?
}

// C1 — canais de notificação por consultoria, com níveis de escalonamento.
model NotificationChannel {
  id            String      @id @default(uuid())
  consultancyId String
  consultancy   Consultancy @relation(fields: [consultancyId], references: [id])
  type          String      // SLACK | TEAMS | WEBHOOK | EMAIL
  name          String
  target        String      // URL do webhook ou e-mail
  minSeverity   String      @default("MEDIUM") // MEDIUM | HIGH | CRITICAL
  level         Int         @default(1)        // 1 = imediato, 2 = escalonamento
  enabled       Boolean     @default(true)
  createdAt     DateTime    @default(now())
}

// C2 — configuração de ticket sync por consultoria (Jira/ServiceNow).
model TicketConfig {
  id            String      @id @default(uuid())
  consultancyId String      @unique
  consultancy   Consultancy @relation(fields: [consultancyId], references: [id])
  provider      String      // JIRA | SERVICENOW
  baseUrl       String
  authUser      String      // e-mail (Jira) ou usuário (ServiceNow)
  authToken     String      // API token (Jira) / senha (ServiceNow) — cifrado
  projectKey    String?     // projeto Jira
  minSeverity   String      @default("HIGH")
  enabled       Boolean     @default(true)
  createdAt     DateTime    @default(now())
}

// B1 — itens operacionais do SAP reportados pelo agente: IDocs em erro, filas qRFC/tRFC.
model SapItem {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String       @id @default(uuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id])
  kind          String       // IDOC | QRFC | TRFC
  direction     String?      // INBOUND | OUTBOUND
  ref           String       // número do IDoc / nome da fila / TID
  messageType   String?      // ORDERS05, MATMAS05, DESADV...
  partner       String?      // parceiro (LS/KU) ou destino RFC
  statusCode    String?      // 51,56,64 / SYSFAIL / CPICERR / RETRY
  statusText    String?
  depth         Int          @default(1)  // profundidade da fila (qRFC) ou nº de LUWs
  remediable    Boolean      @default(false)
  resolved      Boolean      @default(false)
  lastSeenAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  remediations  RemediationAction[]
  @@unique([integrationId, kind, ref])
  @@index([clientId, kind, resolved])
}

// B2 — ação de remediação autônoma: criada na plataforma, aprovada por admin,
// executada pelo agente (pull) com log de antes/depois.
model RemediationAction {
  id            String       @id @default(uuid())
  clientId      String
  environment   String       @default("PRD") // DEV | HML | PRD
  client        Client       @relation(fields: [clientId], references: [id])
  integrationId String?
  sapItemId     String?
  sapItem       SapItem?     @relation(fields: [sapItemId], references: [id])
  actionType    String       // REPROCESS_IDOC | UNLOCK_QUEUE | RETRY_TRFC | REACTIVATE_RFC
  target        String       // ref do objeto (IDoc nº, fila, TID)
  params        Json?
  status        String       @default("PENDING_APPROVAL") // PENDING_APPROVAL|APPROVED|EXECUTING|DONE|FAILED|REJECTED
  requestedById String?
  approvedById  String?
  resultText    String?
  beforeText    String?
  afterText     String?
  requestedAt   DateTime     @default(now())
  approvedAt    DateTime?
  executedAt    DateTime?
  confidence    Int?         // AMS autônomo: 0-100 (confiança da IA/rede na correção)
  autoExecuted  Boolean      @default(false) // executada sem aprovação humana
  @@index([clientId, status])
  @@index([integrationId, status])
}

// B3 — catálogo vivo de interfaces, auto-descoberto pelo agente.
model InterfaceCatalogItem {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String       @id @default(uuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  integrationId String?
  kind          String       // PARTNER_PROFILE | RFC_DEST | MESSAGE_TYPE | ODATA_SERVICE | IDOC_PORT
  name          String       // nome do objeto (parceiro, destino, msg type, serviço)
  detail        String?      // descrição / host / tipo de conexão
  attributes    Json?        // metadados extras (porta, processcode, etc.)
  active        Boolean      @default(true)
  lastSeenAt    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  @@unique([integrationId, kind, name])
  @@index([clientId, kind])
}

// D3 — transportes (STMS/TMS) reportados pelo agente, para correlação com incidentes.
model Transport {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String       @id @default(uuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  integrationId String?
  trNumber      String       // ex.: DEVK900123
  description   String?
  owner         String?
  status        String?      // IMPORTED | ERROR
  target        String?      // sistema alvo (QAS/PRD)
  importedAt    DateTime?
  createdAt     DateTime     @default(now())
  @@unique([clientId, trNumber])
  @@index([clientId])
}

// E1 — amostras de métricas no tempo (para tendência/previsão).
model MetricSample {
  id            String   @id @default(uuid())
  integrationId String
  clientId      String
  latency       Int      @default(0)
  errorRate     Float    @default(0)
  uptime        Float    @default(100)
  queueDepth    Int      @default(0)
  capturedAt    DateTime @default(now())
  @@index([integrationId, capturedAt])
}

// F1/F2 — mensagens do SAP Cloud Integration (CPI) e do AIF.
model CloudItem {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  integrationId String?
  source        String   // CPI | AIF
  artifact      String   // nome do IFlow (CPI) ou interface (AIF)
  messageId     String
  direction     String?  // INBOUND | OUTBOUND
  status        String?  // COMPLETED | FAILED | RETRY | ESCALATED
  error         String?
  occurredAt    DateTime?
  createdAt     DateTime @default(now())
  resolved      Boolean  @default(false)
  aiDiagnosis   String?  // causa raiz + passos de correção gerados pela IA
  aiDiagnosedAt DateTime?
  aiFix         String?  // correção generativa (snippet/config pronto) gerada pela IA
  @@unique([integrationId, source, messageId])
  @@index([clientId, source, resolved])
}

// ====================== S/4HANA Cloud (carro-chefe) ======================
// S0 — Conector cloud por cliente (Communication Arrangement / OData).
model S4Connection {
  id            String   @id @default(uuid())
  clientId      String
  environment   String   @default("PRD") // DEV | HML | PRD — conexão S/4 por ambiente
  client        Client   @relation(fields: [clientId], references: [id])
  baseUrl       String                       // ex.: https://my300000.s4hana.cloud.sap
  authType      String   @default("OAUTH")   // OAUTH | BASIC | CERT
  commUser      String?
  authToken     String?                      // cifrado
  release       String?                      // ex.: 2502
  status        String   @default("PENDING") // PENDING | CONNECTED | ERROR
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  @@unique([clientId, environment])
}

// Basis & Operações — sinais de saúde do landscape coletados pelo agente
// (PI/PO, jobs SM37, dumps ST22, update errors SM13, locks SM12, Gateway log, HANA, segurança/patch).
model OpsSignal {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String    @id @default(uuid())
  clientId      String
  integrationId String?
  category      String    // PIPO | JOB | DUMP | UPDATE_ERR | LOCK | GATEWAY | HANA | SECURITY
  severity      String    @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  title         String
  object        String?
  detail        String?
  ref           String    // chave de dedupe (nome do job / id do dump / objeto bloqueado…)
  occurredAt    DateTime?
  resolved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, category, ref])
  @@index([clientId, category, resolved])
}

// BTP Cockpit — inventário de recursos da SAP BTP por cliente (keys/bindings/destinations/quotas/apps).
model BtpResource {
  environment String   @default("PRD") // DEV | HML | PRD
  id         String    @id @default(uuid())
  clientId   String
  subaccount String?
  kind       String    // SERVICE_KEY | BINDING | DESTINATION | QUOTA | APP
  name       String
  status     String    @default("OK") // OK | WARN | EXPIRED | DOWN
  detail     String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId])
}

// Conectores SAP Cloud BYO (Ariba / SuccessFactors) — uma chave por cliente, espelha o do S/4.
model CloudConnector {
  id         String    @id @default(uuid())
  clientId   String
  product    String    // ARIBA | SUCCESSFACTORS
  baseUrl    String
  apiKey     String    // cifrada
  environment String   @default("PRD") // DEV | HML | PRD — conector por ambiente
  status     String    @default("PENDING") // PENDING | CONNECTED | ERROR
  lastSyncAt DateTime?
  lastResult Json?
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([clientId, product, environment])
  @@index([clientId])
}

// S1.1 — Achados de impacto de upgrade/release.
model UpgradeFinding {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  release       String                       // release alvo (ex.: 2508)
  area          String                       // API | CDS | EXTENSION | FIELD | JOB
  object        String                       // nome do objeto afetado
  impact        String   @default("CHANGED") // BREAKING | DEPRECATED | CHANGED | OK
  detail        String?
  recommendation String?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  @@index([clientId, impact])
}

// S1.2 — Itens que afetam o Clean Core Score.
model CleanCoreItem {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  category      String                       // DEPRECATED_API | CUSTOM_CDS | SIDE_BY_SIDE | IN_APP | MODIFICATION
  object        String
  severity      String   @default("MEDIUM")  // LOW | MEDIUM | HIGH
  points        Int      @default(5)         // desconto no score
  recommendation String?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  @@index([clientId, resolved])
}

// S1.3 — Inventário de APIs liberadas consumidas.
model ApiUsage {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  apiName       String
  version       String?                      // v2 | v4
  scenario      String?                      // SAP_COM_xxxx
  calls30d      Int      @default(0)
  deprecated    Boolean  @default(false)
  deprecationRelease String?
  replacement   String?
  lastSeenAt    DateTime @default(now())
  @@unique([clientId, apiName, version, environment])
}

// S2.1 — Communication Arrangements + certificados.
model CommArrangement {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  scenario      String                       // SAP_COM_xxxx
  name          String
  direction     String?                      // INBOUND | OUTBOUND
  commUser      String?
  status        String   @default("ACTIVE")  // ACTIVE | ERROR | INACTIVE
  certExpiresAt DateTime?
  lastSeenAt    DateTime @default(now())
  @@unique([clientId, scenario, name, environment])
}

// S3.1 — Documentos fiscais (DRC / eDocument).
model FiscalDoc {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  docType       String                       // NFE | NFSE | CTE
  number        String
  status        String   @default("PENDING") // AUTHORIZED | REJECTED | CONTINGENCY | PENDING | CANCELLED
  sefazCode     String?
  message       String?
  amountCents   Int      @default(0)
  remediable    Boolean  @default(false)
  resolved      Boolean  @default(false)
  issuedAt      DateTime?
  createdAt     DateTime @default(now())
  @@unique([clientId, docType, number, environment])
  @@index([clientId, status])
}

// S4.1 — Observabilidade de Event Mesh / eventos de negócio.
model CloudEvent {
  environment String   @default("PRD") // DEV | HML | PRD
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  topic         String
  status        String   @default("DELIVERED") // DELIVERED | DEAD_LETTER | RETRY | PENDING
  subscriber    String?
  lagMs         Int      @default(0)
  occurredAt    DateTime?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  @@index([clientId, status])
}

// Conector REAL do SAP Integration Suite (CPI) via OAuth client-credentials + OData MPL.
model CpiConfig {
  id            String   @id @default(uuid())
  clientId      String
  environment   String   @default("PRD") // DEV | HML | PRD — config CPI por ambiente
  client        Client   @relation(fields: [clientId], references: [id])
  baseUrl       String                       // ex.: https://xxxx.it-cpitrial06.cfapps.../api/v1
  tokenUrl      String                       // ex.: https://xxxx.authentication.../oauth/token
  oauthClientId String
  oauthSecret   String                       // cifrado
  enabled       Boolean  @default(true)
  lastSyncAt    DateTime?
  lastResult    String?
  lastCount     Int      @default(0)
  createdAt     DateTime @default(now())
  @@unique([clientId, environment])
}

// Lead (manifestação de interesse na landing) — cadastro público fechado por enquanto.
model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  role      String?
  employees String?
  message   String?
  source    String?  @default("landing")
  status    String   @default("NEW") // NEW | CONTACTED | QUALIFIED | DISCARDED
  createdAt DateTime @default(now())
  @@index([status, createdAt])
}

model Diagnostic {
  environment String   @default("PRD") // DEV | HML | PRD
  id        String   @id @default(uuid())
  query     String
  response  String   @default("")
  status    String   @default("DONE") // PENDING | DONE | FAILED
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
}

model DeadCode {
  environment String   @default("PRD") // DEV | HML | PRD
  id             String    @id @default(uuid())
  objectName     String
  objectType     String
  lastUsed       DateTime?
  usageCount     Int       @default(0)
  recommendation String
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id])
  createdAt      DateTime  @default(now())
}

// ===== Billing / Assinatura =====

model Plan {
  key                      String         @id // STARTER | PRO | BUSINESS | ENTERPRISE
  name                     String
  description              String?
  priceCents               Int
  interval                 String         @default("MONTH")
  maxClients               Int
  maxIntegrations          Int
  maxAiDiagnosticsPerMonth Int
  maxUsers                 Int
  highlight                Boolean        @default(false) // plano em destaque na UI
  sortOrder                Int            @default(0)
  // Preço dos add-ons (por unidade/mês) quando o limite do plano estoura
  addonIntegrationCents    Int            @default(0)
  addonUserCents           Int            @default(0)
  active                   Boolean        @default(true)
  subscriptions            Subscription[]
}

model Subscription {
  id                     String       @id @default(uuid())
  consultancyId          String       @unique
  consultancy            Consultancy  @relation(fields: [consultancyId], references: [id])
  planKey                String
  plan                   Plan         @relation(fields: [planKey], references: [key])
  status                 String       @default("TRIALING") // TRIALING | ACTIVE | PAST_DUE | SUSPENDED | CANCELED
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  graceUntil             DateTime?
  cancelAtPeriodEnd      Boolean      @default(false)
  autoRenew              Boolean      @default(true) // true = cobrança automática (recorrente); false = pagamento manual por fatura
  extraIntegrations      Int          @default(0) // add-on: integrações além do limite do plano
  extraUsers             Int          @default(0) // add-on: usuários além do limite do plano
  provider               String       @default("manual") // manual | stripe | asaas | iugu
  providerCustomerId     String?
  providerSubscriptionId String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  invoices               Invoice[]
}

model Invoice {
  id                String        @id @default(uuid())
  consultancyId     String
  consultancy       Consultancy   @relation(fields: [consultancyId], references: [id])
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  amountCents       Int
  status            String        @default("OPEN") // OPEN | PAID | FAILED
  providerInvoiceId String?
  dueDate           DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
}

model UsageCounter {
  id            String      @id @default(uuid())
  consultancyId String
  consultancy   Consultancy @relation(fields: [consultancyId], references: [id])
  period        String // YYYY-MM
  aiDiagnostics Int         @default(0)

  @@unique([consultancyId, period])
}

model WebhookEvent {
  id              String   @id @default(uuid())
  provider        String
  providerEventId String   @unique
  processedAt     DateTime @default(now())
}

// ====================== Inovações unicórnio ======================

// Rede Federada de Falhas ("Waze do SAP") — assinatura GLOBAL e anonimizada de falha + correções.
model FailureSignature {
  id            String   @id @default(uuid())
  sigKey        String   @unique // hash normalizado: source + tipo + erro sem ids
  source        String   // CPI | AIF | IDOC | QRFC | TRFC | INTEGRATION
  errorNorm     String   // mensagem normalizada (sem GUIDs/números)
  sampleMessage String?  // exemplo real (anonimizado)
  occurrences   Int      @default(0) // total de ocorrências na rede
  clientsCount  Int      @default(0) // nº de tenants distintos afetados
  fixes         Json?    // [{action, count, successCount, avgMinutes}]
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  @@index([occurrences])
}

// Liga assinatura ↔ tenant de forma anonimizada (hash do clientId) — só para contar distintos.
model FailureSignatureClient {
  sigKey     String
  clientHash String
  lastSeenAt DateTime @default(now())
  @@id([sigKey, clientHash])
}

// AMS Autônomo — política de auto-correção por consultoria.
model AutoHealPolicy {
  consultancyId  String   @id
  enabled        Boolean  @default(false)
  minConfidence  Int      @default(85) // só auto-executa acima desta confiança
  allowedActions Json?    // ["REPROCESS_IDOC","RETRY_TRFC","UNLOCK_QUEUE"]
  updatedAt      DateTime @updatedAt
}

// Reconciliação ponta-a-ponta — define a jornada esperada de um processo de negócio.
model ReconProcess {
  id        String   @id @default(uuid())
  clientId  String
  name      String   // ex.: "Pedido → Faturamento"
  stages    Json     // [{label, source, artifact}] na ordem esperada
  createdAt DateTime @default(now())
  @@index([clientId])
}

// IA BYO — cada consultoria conecta a própria IA (Claude/ChatGPT/Copilot), define a ordem
// (ex.: SAPLINK→Copilot) e pode deixar o Ollama aprender com a IA externa.
model AiProviderConfig {
  consultancyId     String   @id
  primary           String   @default("ollama") // ollama | anthropic | openai | azure
  fallback          String?                     // provedor reserva (opcional)
  learnFromExternal Boolean  @default(false)    // captura respostas da IA externa p/ ensinar o Ollama
  anthropicKey      String?  // Claude (cifrado)
  anthropicModel    String?
  openaiKey         String?  // ChatGPT (cifrado)
  openaiModel       String?
  azureKey          String?  // Copilot / Azure OpenAI (cifrado)
  azureEndpoint     String?
  azureDeployment   String?
  updatedAt         DateTime @updatedAt
}

// Base de conhecimento aprendida com a IA externa (RAG leve p/ deixar o Ollama mais esperto).
model AiKnowledge {
  id            String   @id @default(uuid())
  consultancyId String
  topicKey      String   // assinatura normalizada da pergunta/erro
  question      String
  answer        String
  source        String   // anthropic | openai | azure
  createdAt     DateTime @default(now())
  @@index([consultancyId, topicKey])
}

// SSO (OIDC) BYO — cada consultoria conecta o próprio IdP (Azure AD / Google / Okta).
model SsoConfig {
  consultancyId String   @id
  provider      String   // azure | google | okta
  enabled       Boolean  @default(false)
  clientId      String
  clientSecret  String   // cifrado
  issuer        String   // base de discovery (.well-known/openid-configuration)
  emailDomain   String?  // mapeia o login por domínio (ex.: empresa.com)
  updatedAt     DateTime @updatedAt
}

// Marketplace de Runbooks — playbooks de correção publicados/instalados entre consultorias.
model Runbook {
  id                  String   @id @default(uuid())
  authorConsultancyId String
  authorName          String?  // nome da consultoria autora (vitrine)
  name                String
  description         String?
  category            String?  // CPI | IDOC | FISCAL | RFC | S4 | GERAL
  triggerKeywords     String?  // palavras/assinatura do erro que casa (recomendação)
  steps               Json     // [{ kind:'DIAGNOSE'|'ACTION'|'VALIDATE', title, detail }]
  published           Boolean  @default(false)
  installs            Int      @default(0)
  ratingSum           Int      @default(0)
  ratingCount         Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  @@index([published, category])
}

model RunbookInstall {
  id            String   @id @default(uuid())
  consultancyId String
  runbookId     String
  rating        Int?
  installedAt   DateTime @default(now())
  @@unique([consultancyId, runbookId])
  @@index([consultancyId])
}

// Web Push (PWA) — inscrições de notificação por usuário/consultoria.
model PushSubscription {
  id            String   @id @default(uuid())
  consultancyId String
  userId        String?
  endpoint      String   @unique
  keys          Json     // { p256dh, auth }
  createdAt     DateTime @default(now())
  @@index([consultancyId])
}

// ChatOps — token de canal (WhatsApp/Telegram) por consultoria.
model ChatOpsConfig {
  consultancyId String   @id
  token         String   @unique
  enabled       Boolean  @default(true)
  channel       String?  // whatsapp | telegram | generic
  updatedAt     DateTime @updatedAt
}

// Reform Readiness Radar — prontidão CBS/IBS por cliente (SÓ monitora; não calcula nem transmite).
model ReformReadiness {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  environment   String    @default("PRD")
  area          String    // SAP_NOTES | TAX_FIELDS | CONDITION_TECHNIQUE | NFE_LAYOUT | DRC | MASTER_DATA
  title         String
  status        String    @default("PENDING") // OK | PENDING | RISK
  phase         String?   // 2026 | 2027 | 2033 (fase da transição)
  detail        String?
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  @@unique([clientId, area])
  @@index([clientId])
}

// Indirect Access / Licensing Radar — uso x direito de licença por cliente (monitoramento).
model LicenseItem {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  environment   String    @default("PRD")
  metric        String    // ex.: "Documentos acesso digital/mês", "Usuários nomeados"
  used          Int       @default(0)
  entitled      Int       @default(0)
  unit          String?   // docs | users | engine
  riskLevel     String    @default("OK") // OK | WARN | RISK
  estCostBrl    Float     @default(0)
  detail        String?
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  @@unique([clientId, metric])
  @@index([clientId])
}

// Log de atividade do sistema (auditoria de acesso/edição) por consultoria.
model ActivityLog {
  id            String   @id @default(uuid())
  consultancyId String
  userId        String?
  userEmail     String?
  action        String   // view | create | edit | delete | login | other
  method        String?
  path          String
  detail        String?
  status        Int?
  ip            String?
  createdAt     DateTime @default(now())
  @@index([consultancyId, createdAt])
}

// Cache de respostas da IA (por escopo = consultoria, ou "global"). Acelera prompts repetidos.
model AiCache {
  id        String   @id @default(uuid())
  scope     String   // consultancyId ou "global"
  keyHash   String   // sha256(system + user)
  response  String
  provider  String?
  hits      Int      @default(0)
  createdAt DateTime @default(now())
  @@unique([scope, keyHash])
  @@index([createdAt])
}
