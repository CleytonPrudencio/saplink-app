generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Consultancy {
  id            String         @id @default(uuid())
  name          String
  cnpj          String?        @unique
  plan          String         @default("STARTER") // legado; fonte da verdade = Subscription
  logoUrl       String?
  primaryColor  String?        // white-label (hex)
  createdAt     DateTime       @default(now())
  users         User[]
  clients       Client[]
  subscription  Subscription?
  invoices      Invoice[]
  usageCounters UsageCounter[]
}

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  password      String
  name          String
  role          String               @default("CONSULTANCY_USER") // PLATFORM_ADMIN | CONSULTANCY_ADMIN | CONSULTANCY_USER
  consultancyId String
  consultancy   Consultancy          @relation(fields: [consultancyId], references: [id])
  createdAt     DateTime             @default(now())
  resetTokens   PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Client {
  id            String        @id @default(uuid())
  name          String
  cnpj          String?
  consultancyId String
  consultancy   Consultancy   @relation(fields: [consultancyId], references: [id])
  healthScore   Int           @default(0)
  integrations  Integration[]
  alerts        Alert[]
  diagnostics   Diagnostic[]
  deadCode      DeadCode[]
  createdAt     DateTime      @default(now())
}

model Integration {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String
  status      String   @default("ACTIVE")
  config      Json?
  latency     Int      @default(0)
  errorRate   Float    @default(0)
  uptime      Float    @default(100)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  alerts      Alert[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Alert {
  id            String       @id @default(uuid())
  type          String
  severity      String
  message       String
  resolved      Boolean      @default(false)
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id])
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id])
  createdAt     DateTime     @default(now())
  resolvedAt    DateTime?
}

model Diagnostic {
  id        String   @id @default(uuid())
  query     String
  response  String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
}

model DeadCode {
  id             String    @id @default(uuid())
  objectName     String
  objectType     String
  lastUsed       DateTime?
  usageCount     Int       @default(0)
  recommendation String
  clientId       String
  client         Client    @relation(fields: [clientId], references: [id])
  createdAt      DateTime  @default(now())
}

// ===== Billing / Assinatura =====

model Plan {
  key                      String         @id // STARTER | PRO | ENTERPRISE
  name                     String
  priceCents               Int
  interval                 String         @default("MONTH")
  maxClients               Int
  maxIntegrations          Int
  maxAiDiagnosticsPerMonth Int
  maxUsers                 Int
  active                   Boolean        @default(true)
  subscriptions            Subscription[]
}

model Subscription {
  id                     String       @id @default(uuid())
  consultancyId          String       @unique
  consultancy            Consultancy  @relation(fields: [consultancyId], references: [id])
  planKey                String
  plan                   Plan         @relation(fields: [planKey], references: [key])
  status                 String       @default("TRIALING") // TRIALING | ACTIVE | PAST_DUE | SUSPENDED | CANCELED
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  graceUntil             DateTime?
  cancelAtPeriodEnd      Boolean      @default(false)
  provider               String       @default("manual") // manual | stripe | asaas | iugu
  providerCustomerId     String?
  providerSubscriptionId String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  invoices               Invoice[]
}

model Invoice {
  id                String        @id @default(uuid())
  consultancyId     String
  consultancy       Consultancy   @relation(fields: [consultancyId], references: [id])
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id])
  amountCents       Int
  status            String        @default("OPEN") // OPEN | PAID | FAILED
  providerInvoiceId String?
  dueDate           DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
}

model UsageCounter {
  id            String      @id @default(uuid())
  consultancyId String
  consultancy   Consultancy @relation(fields: [consultancyId], references: [id])
  period        String // YYYY-MM
  aiDiagnostics Int         @default(0)

  @@unique([consultancyId, period])
}

model WebhookEvent {
  id              String   @id @default(uuid())
  provider        String
  providerEventId String   @unique
  processedAt     DateTime @default(now())
}
